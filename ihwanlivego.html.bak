<html lang="id">
<head>
<meta charset="UTF-8">
<title>BIGO Live Pro Simulation</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body{margin:0;background:#000;font-family:Arial,Helvetica,sans-serif;color:#fff;overflow:hidden}

/* VIDEO BACKGROUND */
video{position:fixed;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1}

/* HOST PROFILE (TOP LEFT) */
.host-profile{
  position:absolute;top:12px;left:12px;display:flex;align-items:center;gap:8px;background:rgba(0,0,0,.45);padding:6px 10px;border-radius:20px;z-index:50
}
.host-profile img{width:38px;height:38px;border-radius:50%;border:2px solid #ffcc00}
.host-info{font-size:12px;line-height:1.2}
/* Elemen yang dilingkari: Tombol Follow (+) */
.follow-btn{background:#00d1ff;color:#000;font-size:12px;font-weight:bold;padding:4px 8px;border-radius:12px;cursor:pointer}

/* ONLINE VIEWERS */
.online-viewers{font-size:11px;color:#ffd700;margin-top:2px;opacity:.85}

/* COMMENTS AREA (BOTTOM LEFT) */
.comments{position:absolute;bottom:90px;left:10px;width:75%;font-size:13px;z-index:50}
.comment{display:flex;align-items:center;gap:8px;margin-bottom:6px;background:rgba(0,0,0,.45);padding:4px 8px;border-radius:12px}
.comment img{width:26px;height:26px;border-radius:50%}

/* GIFT ANIMATIONS (FLOWER COMBO) */
.flower-banner{
  position:absolute;left:12px;top:35%;display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.6);padding:12px 16px;border-radius:16px;animation:fadeUp 3.6s ease forwards;z-index:45
}
.flower-banner img{width:56px;height:56px;border-radius:50%}
.badge{background:linear-gradient(45deg,#ffd700,#ff9900);color:#000;font-size:11px;font-weight:bold;padding:2px 6px;border-radius:8px;margin-left:4px}
.gift{font-size:46px}
.combo{font-size:28px;font-weight:bold;color:#ffeb3b;margin-left:6px;animation:pulse .6s infinite alternate}

@keyframes pulse{from{transform:scale(1)}to{transform:scale(1.2)}}
@keyframes fadeUp{0%{opacity:0;transform:translateY(30px)}15%{opacity:1}100%{opacity:0;transform:translateY(-40px)}}

/* VEHICLE GIFT ANIMATION */
.vehicle-gift{
  position:absolute;left:-120%;top:40%;display:flex;align-items:center;gap:16px;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);padding:18px 26px;border-radius:18px;z-index:40;animation:vehicleMove 6s ease-in-out forwards
}
.vehicle-avatar img{width:56px;height:56px;border-radius:50%}
.vehicle-level{background:linear-gradient(45deg,#ffd000,#ff9f00);color:#000;font-size:12px;font-weight:bold;padding:4px 8px;border-radius:10px;position:absolute;bottom:-6px;left:-6px}
.vehicle-text{color:#fff;margin-left:12px}
.vehicle-name{color:#ffd76a;font-weight:bold;font-size:16px}
.vehicle-sub{font-size:14px;opacity:.9}
.vehicle-img{height:120px;filter:drop-shadow(0 10px 18px rgba(0,0,0,.45))}

@keyframes vehicleMove{
  0%{transform:translateX(0) scale(.9);opacity:0}
  10%{opacity:1}
  40%{transform:translateX(120vw) scale(1)}
  100%{transform:translateX(140vw) scale(1.05);opacity:0}
}

/* BOTTOM BAR INTERFACE */
.bottom-bar{position:absolute;bottom:0;left:0;width:100%;height:70px;background:rgba(0,0,0,.7);display:flex;justify-content:space-around;align-items:center;z-index:50}
.icon{font-size:22px;cursor:pointer}

/* LIKE/TAP ANIMATION */
.tap{position:absolute;font-size:26px;animation:tapUp 2.6s ease-out forwards;pointer-events:none;z-index:60}
@keyframes tapUp{from{opacity:1;transform:translateY(0)}to{opacity:0;transform:translateY(-160px) scale(1.4)}}

/* LEADERBOARD & STATUS */
.leaderboard{
  position:absolute;top:60px;right:12px;width:120px;background:rgba(0,0,0,.45);padding:8px;border-radius:12px;font-size:12px;z-index:55
}
.leaderboard h4{margin:0 0 6px 0;font-size:13px;text-align:center}
.leaderboard div{display:flex;justify-content:space-between;margin-bottom:4px}

.host-status{position:absolute;top:70px;left:12px;display:flex;gap:8px;z-index:50}
.status-item{display:flex;align-items:center;gap:6px;padding:6px 10px;background:rgba(0,0,0,.55);border-radius:14px;font-size:12px;font-weight:bold}
.status-item.coin{color:#ffd700}
.status-item.star{background:linear-gradient(45deg,#ff8bd8,#ff5fb0);color:#fff;cursor:pointer}

/* TOP SUPPORTER BAR (TOP RIGHT) */
.top-supporter{position:absolute;top:18px;right:2px;display:flex;align-items:center;gap:5px;z-index:70}
.supporter{position:relative;width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,.22);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:bold}
.supporter img{width:100%;height:100%;border-radius:50%;object-fit:cover}
.supporter-count{position:absolute;bottom:-2px;font-size:8px;padding:0 4px;background:#ff0000;border-radius:50%}
.supporter.gold{border:2px solid #ffd700}
.supporter.crown{border:2px solid #a6d7ff}
.supporter.total, .supporter.close{width:28px;height:28px;font-size:9px}
/* Elemen yang dilingkari: Tombol Close (X) */
.supporter.close{background:rgba(0,0,0,.45);cursor:pointer}
/* === POPUP 18+ === */
.age-popup{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.85);
  display:none;
  align-items:center;
  justify-content:center;
  z-index:9999;
}

.age-box{
  width:90%;
  max-width:360px;
  background:#111;
  border-radius:16px;
  padding:22px;
  text-align:center;
  box-shadow:0 0 30px rgba(255,0,0,.25);
}

.age-box h2{
  color:#ff3b3b;
  margin:0 0 10px;
  font-size:22px;
}

.age-box p{
  font-size:14px;
  line-height:1.5;
  opacity:.9;
}

.age-actions{
  display:flex;
  gap:12px;
  margin-top:18px;
}

.age-btn{
  flex:1;
  padding:12px 0;
  border-radius:12px;
  font-weight:bold;
  cursor:pointer;
  border:none;
  font-size:14px;
}

.age-btn.cancel{
  background:#333;
  color:#fff;
}

.age-btn.continue{
  background:linear-gradient(45deg,#ff0000,#ff6a00);
  color:#fff;
}
</style>
</head>

<body>
  <script>
(function(){
  function kill(){
    document.documentElement.innerHTML="";
  }

  const LOCK_URL = "https://denabilock.denabidin97.workers.dev";
  const SIGN = "DEN_ABI_LOCK_V1";

  fetch(LOCK_URL + "?domain=" + location.hostname + "&sign=" + SIGN)
    .then(r => r.ok ? r.text() : "DENY")
    .then(t => {
      if (t.trim() !== "OK") {
        console.warn("SERVER LOCK DENY");
        kill();
      }
    })
    .catch(err => {
      console.warn("SERVER LOCK ERROR", err);
      // sementara JANGAN kill dulu
    });
})();
</script>
    <script>
(function(){

function kill(){
  document.documentElement.innerHTML = "";
  document.open();document.write("");document.close();
}


const SIGNATURE = `
========================================
 Template Author : DEN ABI
 Ownership      : Hak cipta dilindungi
 Notice         : DILARANG memperjualbelikan
                  template ini tanpa izin
                  tertulis dari author.
========================================
`.trim();
const walker = document.createTreeWalker(
  document,
  NodeFilter.SHOW_COMMENT,
  null,
  false
);

let found = false;
while(walker.nextNode()){
  const c = walker.currentNode.nodeValue.trim();
  if(c === SIGNATURE){
    found = true;
    break;
  }
}
if(!found){
  kill();
}

})();
</script>
<video autoplay muted loop playsinline id="liveVideo">
  <source src="https://ik.imagekit.io/laura/Syaboba_Remes_Tobrut_Sambil_Colmek.mp4" type="video/mp4">
</video>

<div class="host-profile">
  <img src="https://i.ibb.co.com/3yWtV53m/images-1-13.jpg">
  <div class="host-info">
    <b>eva_marie</b><br>
    <span class="online-viewers">
      ❤️ Likes: <span id="likeCount">0</span><br>
      👥 Online: <span id="onlineCount">1.28K</span>
    </span>
  </div>
  <div class="follow-btn" id="ad-follow">+</div>
</div>

<div class="host-status">
  <div class="status-item coin">🪙 <span id="coinCount">3719796</span></div>
  <div class="status-item star" id="starBox">⭐ <span id="starLevel">4</span> Star</div>
</div>

<div class="comments" id="comments"></div>
<div id="giftArea"></div>

<div class="leaderboard" id="leaderboard">
  <h4>Top Gifts</h4>
</div>

<div class="top-supporter">
  <div class="supporter gold"><img src="https://i.pravatar.cc/100?img=12"><span class="supporter-count">14</span></div>
  <div class="supporter crown"><img src="https://i.pravatar.cc/100?img=32"><span class="supporter-count">10</span></div>
  <div class="supporter"><img src="https://i.pravatar.cc/100?img=5"><span class="supporter-count">5</span></div>
  <div class="supporter total">495</div>
  <div class="supporter close" id="ad-close">✕</div>
</div>

<div class="bottom-bar">
  <div class="icon">😊</div>
  <div class="icon">💬</div>
  <div class="icon" id="ad-link">🔗</div>
  <div class="icon" id="ad-menu">≡</div>
  <div class="icon" id="ad-gift">🎁</div>
</div>

<script>
const video = document.getElementById("liveVideo");


/* ===== KONFIGURASI IKLAN ===== */
// Tempel link Adsterra kamu di sini 🔗
const myAdLink = "https://jndgxn.magicgirllthere.com/?utm_source=da57dc555e50572d&&ban=fb&s1=232783&s2=2110304&click_id=ALHAMDULILLAH";

function openAd(e) {
  e.stopPropagation(); // Agar klik tidak memicu efek tap hati
  window.open(myAdLink, '_blank');
}

// Menghubungkan semua elemen yang dilingkari ke fungsi iklan
document.getElementById("ad-follow").onclick = openAd;
document.getElementById("ad-close").onclick = openAd;
document.getElementById("ad-link").onclick = openAd;
document.getElementById("ad-menu").onclick = openAd;
document.getElementById("ad-gift").onclick = openAd;


/* ===== DATA USERS & LOGIKA LAINNYA ===== */
const users = [
 {name:"Jeremy", lvl:35, gift:0, avatar: "https://i.pravatar.cc/150?img=11"},
 {name:"Vina",   lvl:28, gift:0, avatar: "https://i.pravatar.cc/150?img=5"},
 {name:"Rina",   lvl:41, gift:0, avatar: "https://i.pravatar.cc/150?img=9"},
 {name:"Bayu",   lvl:22, gift:0, avatar: "https://i.pravatar.cc/150?img=12"},
 {name:"Dewi",   lvl:30, gift:0, avatar: "https://i.pravatar.cc/150?img=16"}
];

const texts = ["present sis🔥","come watch","great live","the live makes you drool","support darling"];
const rand = a => a[Math.floor(Math.random()*a.length)];

const box = document.getElementById("comments");
setInterval(() => {
 const u = rand(users);
 const d = document.createElement("div");
 d.className = "comment";
 d.innerHTML = `<img src="${u.avatar}"><b>${u.name}</b>: ${rand(texts)}`;
 box.appendChild(d);
 if(box.children.length > 6) box.removeChild(box.firstChild);
}, 1600);

function updateLeaderboard(){
 const lb = document.getElementById("leaderboard");
 lb.innerHTML = "<h4>Top Gifts</h4>";
 [...users].sort((a,b)=>b.gift-a.gift).forEach(u=>{
   if(u.gift > 0) lb.innerHTML += `<div><b>${u.name}</b><span>🌹${u.gift}</span></div>`;
 });
}

function showComboGift(){
 const u = rand(users);
 const combo = [1, 5, 10][Math.floor(Math.random()*3)];
 u.gift += combo;
 updateLeaderboard();
 const g = document.createElement("div");
 g.className = "flower-banner";
 g.innerHTML = `
  <img src="${u.avatar}">
  <b>${u.name}</b> <span class="badge">Lv.${u.lvl}</span>
  <div class="gift">🌹</div>
  <div class="combo">x${combo}</div>
 `;
 document.getElementById("giftArea").appendChild(g);
 setTimeout(()=>g.remove(), 3600);
}
setInterval(showComboGift, 4200);

const vehicles = [
 {name:"Jeremy", lvl:35, avatar: "https://i.pravatar.cc/150?img=11", text:"Mengirim Super Car", img:"https://i.ibb.co.com/KpgbvtPK/red-sports-car-with-gullwing-doors-isolated-transparent-background-1092965-15426-removebg-preview.png"},
 {name:"Rina",   lvl:41, avatar: "https://i.pravatar.cc/150?img=9", text:"Mengirim Luxury Train", img:"https://i.ibb.co.com/Q39tv2hT/Pngtree-golden-luxury-train-with-transparent-17521610.png"}
];
function showVehicleGift(){
 const v = rand(vehicles);
 const el = document.createElement("div");
 el.className = "vehicle-gift";
 el.innerHTML = `
  <div class="vehicle-avatar"><img src="${v.avatar}"><div class="vehicle-level">Lv.${v.lvl}</div></div>
  <div class="vehicle-text"><div class="vehicle-name">${v.name}</div><div class="vehicle-sub">${v.text}</div></div>
  <img class="vehicle-img" src="${v.img}">
 `;
 document.body.appendChild(el);
 setTimeout(()=>el.remove(), 6000);
}
setInterval(showVehicleGift, 16000);

let likeCount = 0;
function triggerTap(x, y) {
  likeCount++;
  document.getElementById("likeCount").textContent = likeCount.toLocaleString();
  const t = document.createElement("div");
  t.className = "tap";
  t.textContent = rand(["❤️","🔥","✨","🌟"]);
  t.style.left = (x - 10) + "px";
  t.style.top = (y - 10) + "px";
  document.body.appendChild(t);
  setTimeout(()=>t.remove(), 2600);
}

function startAutoTap() {
  setInterval(() => {
    const randomX = (window.innerWidth * 0.6) + Math.random() * (window.innerWidth * 0.3);
    const randomY = (window.innerHeight * 0.5) + Math.random() * (window.innerHeight * 0.3);
    triggerTap(randomX, randomY);
  }, 400); 
}
startAutoTap(); 

document.addEventListener("click", e => {
 if(e.target.closest('.icon, .star, .close, .follow-btn')) return;
 triggerTap(e.clientX, e.clientY);
});

let online=document.getElementById("onlineCount");
let viewerNum=1280;
setInterval(()=>{
 viewerNum += Math.floor(Math.random()*3+1);
 online.textContent = viewerNum.toLocaleString();
}, 2200);

</script>
<div class="age-popup" id="agePopup">
  <div class="age-box">
    <h2>🔞 warning 18+</h2>
    <p>
      This content is for ages only <b>18 years and above</b>.<br>
      By continuing, you agree and assume full responsibility.
    </p>

    <div class="age-actions">
      <button class="age-btn cancel" id="ageCancel">❌ Cancel</button>
      <button class="age-btn continue" id="ageContinue">▶ Next</button>
    </div>
  </div>
</div>
<script>
window.addEventListener("load", () => {

  const video = document.getElementById("liveVideo");
  const popup = document.getElementById("agePopup");
  const btnCancel = document.getElementById("ageCancel");
  const btnContinue = document.getElementById("ageContinue");

  if (!video || !popup || !btnCancel || !btnContinue) {
    console.log("Element belum siap");
    return;
  }
// ▶ KODE IKLAN ADSTERA DIBAWAH
  const adLink = "https://jndgxn.magicgirllthere.com/?utm_source=da57dc555e50572d&&ban=fb&s1=232783&s2=2110304&click_id=ALHAMDULILLAH";

  let unlocked = false;
  let popupTimer = null;
  let cancelCount = 0;

  // ▶ VIDEO JALAN DULU
  video.muted = true;
  video.play().catch(()=>{});

  // ⏱️ POPUP TIAP 5 DETIK
  function startPopupLoop(){
    popupTimer = setInterval(() => {
      if (unlocked) return;

      video.pause();
      popup.style.display = "flex";
    }, 5000);
  }
  startPopupLoop();

  // ❌ CANCEL
  btnCancel.onclick = () => {
    cancelCount++;

    // Cancel ke-5 baru iklan
    if (cancelCount >= 5) {
      window.open(adLink, "_blank");
    }

    popup.style.display = "none";
    video.play().catch(()=>{});

    clearInterval(popupTimer);
    startPopupLoop();
  };

  // ✅ LANJUTKAN (IKLAN + UNLOCK)
  btnContinue.onclick = () => {
    window.open(adLink, "_blank");
    unlocked = true;
    popup.style.display = "none";
    clearInterval(popupTimer);
    video.muted = false;
    video.play().catch(()=>{});
  };

  // 🚫 BLOK PLAY SAAT POPUP
  video.addEventListener("play", e => {
    if (!unlocked && popup.style.display === "flex") {
      e.preventDefault();
      video.pause();
    }
  });

});
</script>
</body>
</html>
